@model HybridCachePlayground.Web.Models.CacheSetRequest
@{
    ViewData["Title"] = "Set Cache Entry";
}

<h2 class="mb-4">Set Cache Entry</h2>
<p class="text-muted">
    Stores a value in HybridCache using
    <code>HybridCache.SetAsync(key, value, options, tags)</code>.
</p>

<div class="row">
    <div class="col-md-7">
        <form asp-action="Set" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Key" class="form-label fw-semibold">Cache Key</label>
                <input asp-for="Key" class="form-control" placeholder="e.g. user:42" />
                <span asp-validation-for="Key" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Value" class="form-label fw-semibold">Value <span class="text-muted fw-normal">(any string or JSON)</span></label>
                <textarea asp-for="Value" class="form-control font-monospace" rows="5"
                          placeholder='e.g. {"name":"Alice","role":"admin"}'></textarea>
                <span asp-validation-for="Value" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Tags" class="form-label fw-semibold">
                    Tags <span class="text-muted fw-normal">(comma-separated)</span>
                </label>
                <input asp-for="Tags" class="form-control" placeholder="e.g. users, tenant-1, admin" />
                <div class="form-text">
                    Tags allow bulk invalidation via <em>Remove by Tag</em>.
                    HybridCache propagates tag-based eviction across L1 and L2.
                </div>
            </div>
            <div class="mb-4">
                <label asp-for="ExpirationMinutes" class="form-label fw-semibold">Expiration (minutes)</label>
                <input asp-for="ExpirationMinutes" type="number" class="form-control" min="1" max="1440" />
                <span asp-validation-for="ExpirationMinutes" class="text-danger small"></span>
                <div class="form-text">L1 (local) TTL = min(this, 2 min). L2 TTL = this value.</div>
            </div>
            <button type="submit" class="btn btn-primary">Store in Cache</button>
            <a asp-controller="Home" asp-action="Index" class="btn btn-link">Back to Dashboard</a>
        </form>
    </div>

    <div class="col-md-5">
        <div class="card border-secondary">
            <div class="card-header bg-secondary text-white small">API used</div>
            <div class="card-body">
                <pre class="small mb-0"><code>await hybridCache.SetAsync(
    key,
    value,
    new HybridCacheEntryOptions
    {
        Expiration = TimeSpan.FromMinutes(ttl),
        LocalCacheExpiration =
            TimeSpan.FromMinutes(2)
    },
    tags: ["tag1", "tag2"]);</code></pre>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
