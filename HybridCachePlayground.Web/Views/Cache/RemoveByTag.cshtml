@model HybridCachePlayground.Web.Models.CacheRemoveByTagRequest
@{
    ViewData["Title"] = "Remove by Tag";
    var allTags = ViewData["AllTags"] as List<string> ?? new();

    // Derive wildcard patterns from known tags: "factory-generated" → "factory-*", "users" → "users*"
    var wildcardPatterns = allTags
        .Select(t => t.Contains('-') ? t.Split('-')[0] + "-*" : t + "*")
        .Distinct()
        .OrderBy(p => p)
        .ToList();
}

<h2 class="mb-4">Remove by Tag</h2>
<p class="text-muted">
    Evicts all entries sharing a tag using
    <code>HybridCache.RemoveByTagAsync(tag)</code> — the key feature of tag-based invalidation.
</p>

<div class="row g-4">
    <!-- ── Left column ── -->
    <div class="col-md-7">

        <!-- Exact match -->
        <div class="card mb-4">
            <div class="card-header fw-semibold">Exact Tag Match</div>
            <div class="card-body">
                <form asp-action="RemoveByTag" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="Tag" class="form-label fw-semibold">Tag</label>
                        <input asp-for="Tag" id="Tag" class="form-control" placeholder="e.g. users" />
                        <span asp-validation-for="Tag" class="text-danger small"></span>
                        <div class="form-text">
                            All entries stored with this exact tag will be evicted from both L1 and L2.
                        </div>
                        @if (allTags.Any())
                        {
                            <div class="mt-2">
                                <small class="text-muted">Known tags: </small>
                                @foreach (var t in allTags)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-danger chip-suggest"
                                            data-fill-id="Tag" data-fill-val="@t">@t</button>
                                }
                            </div>
                        }
                    </div>
                    <button type="submit" class="btn btn-danger">Evict by Tag</button>
                </form>
            </div>
        </div>

        <!-- Wildcard match -->
        <div class="card border-warning">
            <div class="card-header bg-warning fw-semibold">
                Wildcard Tag Eviction <small class="fw-normal ms-1">(<code>*</code>)</small>
            </div>
            <div class="card-body">
                @if (wildcardPatterns.Any())
                {
                    <p class="small text-muted mb-2">
                        Patterns auto-derived from known tags. Click one to evict all matching entries immediately.
                    </p>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @foreach (var pattern in wildcardPatterns)
                        {
                            <form asp-action="RemoveByTagWildcard" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="wildcardPattern" value="@pattern" />
                                <button type="submit" class="btn btn-warning text-dark fw-semibold">
                                    @pattern
                                </button>
                            </form>
                        }
                    </div>
                    <hr style="border-color:#3a3d48;" />
                }
                else
                {
                    <p class="small text-muted mb-3">No tags in registry yet. Set some entries first.</p>
                }

                <!-- Remove All -->
                <form asp-action="RemoveByTagWildcard" method="post" class="d-inline"
                      onsubmit="return confirm('Remove ALL cached entries? This cannot be undone.');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="wildcardPattern" value="*" />
                    <button type="submit" class="btn btn-danger">
                        &#128465; Remove All (<code>*</code>)
                    </button>
                </form>
                <div class="form-text mt-1">Matches every tag in the registry — use with care.</div>
            </div>
        </div>

        <a asp-controller="Home" asp-action="Index" class="btn btn-link mt-3">Back to Dashboard</a>
    </div>

    <!-- ── Right column ── -->
    <div class="col-md-5">
        <div class="card">
            <div class="card-header bg-secondary small">Exact — API used</div>
            <div class="card-body">
                <pre class="small mb-0"><code>await hybridCache.RemoveByTagAsync(tag);</code></pre>
            </div>
        </div>
        <div class="card border-warning mt-3">
            <div class="card-header bg-warning small">Wildcard — how it works</div>
            <div class="card-body small">
                <p>
                    HybridCache does not natively support wildcard tag removal.
                    This feature is implemented in the service layer:
                </p>
                <ol class="mb-0">
                    <li>The glob pattern is converted to a Regex.</li>
                    <li>All known tags are scanned for matches.</li>
                    <li><code>RemoveByTagAsync</code> is called once per matched tag.</li>
                </ol>
                <p class="mt-2 mb-0 text-muted">
                    Wildcard buttons are auto-derived from the Tag Registry using the
                    prefix before the first <code>-</code>.
                </p>
            </div>
        </div>
        <div class="card border-info mt-3">
            <div class="card-header bg-info small">Tag invalidation pattern</div>
            <div class="card-body small">
                <ul class="mb-0">
                    <li>Tag <code>tenant-5</code> → evict all data for tenant 5</li>
                    <li>Tag <code>users</code> → evict all user-related entries</li>
                    <li>Tag <code>factory-*</code> → evict all factory-generated entries</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
    document.querySelectorAll('[data-fill-id]').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.getElementById(btn.getAttribute('data-fill-id')).value = btn.getAttribute('data-fill-val');
        });
    });
    </script>
}
